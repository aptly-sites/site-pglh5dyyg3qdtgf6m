---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import { site } from '../config';
---

<BaseLayout
  title={`Available Rentals | ${site.companyName}`}
  description={`Browse available rental properties managed by ${site.companyName}.`}
>
  <!-- NAV -->
  <nav class="nav" id="nav">
    <div class="container" style="display:flex;align-items:center;justify-content:space-between;height:64px;">
      <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:10px;">
        {site.logoPath
          ? <img src={site.logoPath} alt={site.companyName} style="height:40px;width:auto;object-fit:contain;" />
          : <span style="font-size:18px;font-weight:800;color:var(--color-ink);">{site.companyName}</span>
        }
      </a>
      <div style="display:flex;align-items:center;gap:32px;" class="nav-links">
        {site.nav.map(link => (
          <a
            href={link.href.startsWith('#') ? `/${link.href}` : link.href}
            class="nav-link"
            style={link.href === '/rentals' ? `color:var(--color-primary);font-weight:600;` : ''}
          >{link.label}</a>
        ))}
        <a href="/#contact" class="btn-primary" style="padding:9px 18px;font-size:14px;">
          Get Started
        </a>
      </div>
      <button id="nav-toggle" style="display:none;background:none;border:none;cursor:pointer;padding:4px;" aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    <div id="mobile-menu" style="display:none;padding:16px 24px 20px;border-top:1px solid #edf0f5;">
      {site.nav.map(link => (
        <a href={link.href.startsWith('#') ? `/${link.href}` : link.href} class="nav-link" style="display:block;padding:10px 0;">{link.label}</a>
      ))}
      <a href="/#contact" class="btn-primary" style="margin-top:12px;width:100%;justify-content:center;">
        Get Started
      </a>
    </div>
  </nav>

  <!-- WIDGET -->
  <div style="padding-top:64px;height:100vh;display:flex;flex-direction:column;">
    <iframe
      src={site.listingsWidgetUrl}
      width="100%"
      style="flex:1;border:none;display:block;"
      title="Available Rentals"
      loading="lazy"
      allow="payment"
    />
  </div>
</BaseLayout>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 20);
  });
  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = mobileMenu?.style.display === 'block';
    if (mobileMenu) mobileMenu.style.display = open ? 'none' : 'block';
  });
  const navLinks = document.querySelector('.nav-links') as HTMLElement;
  const updateNav = () => {
    if (navLinks) navLinks.style.display = window.innerWidth < 700 ? 'none' : 'flex';
    if (toggle) (toggle as HTMLElement).style.display = window.innerWidth < 700 ? 'block' : 'none';
  };
  updateNav();
  window.addEventListener('resize', updateNav);
</script>
